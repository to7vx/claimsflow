# ──────────────────────────────────────────────────────────────────
# ClaimsFlow environment configuration
# Copy this file to `.env` and fill in the values you care about.
# ──────────────────────────────────────────────────────────────────

# --- App ----------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated origins for the dashboard)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# API key required for write endpoints. Generate a random one for prod.
API_KEY=dev-local-key-change-me

# HMAC secret for the n8n webhook signature header (X-ClaimsFlow-Signature)
WEBHOOK_HMAC_SECRET=dev-hmac-secret-change-me

# --- Database -----------------------------------------------------
# SQLite (zero-config dev). Falls back automatically if Postgres unreachable.
DATABASE_URL=sqlite:///./claimsflow.db
# Postgres (Docker / prod):
# DATABASE_URL=postgresql+psycopg://claimsflow:claimsflow@localhost:5432/claimsflow

# --- LLM Provider -------------------------------------------------
# One of: ollama | anthropic | openai
LLM_PROVIDER=ollama

# Ollama (default — free local). Install: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Pipeline tuning ----------------------------------------------
# Hard cap on auto-approvable claim amount (SAR). Above this -> audit queue.
AUTO_APPROVE_AMOUNT_CEILING_SAR=50000

# Cache TTL for medical-necessity LLM calls, in seconds.
MEDICAL_NECESSITY_CACHE_TTL=86400

# Rate limit (requests / minute) on the API.
API_RATE_LIMIT_PER_MINUTE=120
